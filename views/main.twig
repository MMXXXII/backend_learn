{% extends "__layout.twig" %}

{% import 'macros.twig' as macros %}

{% block content %}
<div class="container mt-2 mb-2">
    <div class="d-flex flex-wrap justify-content-center gap-3">
        {% for system in os_list %}
            <div class="card">
                <img src="{{ system.image }}" class="card-img-top" alt="{{ system.title }}">
                <div class="card-body text-center">
                    <h5 class="card-title">
                        <a class="btn btn-light" href="/os_list/{{ system.id }}">{{ system.title }}</a>
                    </h5>
                    <div class="btn-container">
                        {{ macros.btn("Картинки", "/os_list/" ~ system.id ~ "/image", false) }}
                        {{ macros.btn("Описание", "/os_list/" ~ system.id ~ "/info", false) }}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
